# Copy to .env and fill in.

# OpenAI (used by both the Agents SDK and embeddings)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o                 # reasoning/judgment (advisor, researcher)
OPENAI_VISION_MODEL=gpt-4o-mini    # cheap screen scraping (collector, redactor)
OPENAI_EMBED_MODEL=text-embedding-3-small

# Weights & Biases Weave
WANDB_API_KEY=...
WEAVE_PROJECT=scamguard             # appears in the Weave UI
WEAVE_DISABLED=false                # set true to run without Weave

# Redis (Redis Stack recommended for vector search)
REDIS_URL=redis://localhost:6379

# Server
SCAN_INTERVAL_SECONDS=30
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4000
